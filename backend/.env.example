# Copy this file to backend/.env for local development.
# For Render, set these values in the Render dashboard instead of committing a real .env file.
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=false
PLATFORM_URL=http://127.0.0.1:5000
FRONTEND_APP_URL=http://127.0.0.1:5000
# Leave DATABASE_URL unset locally to use backend/instance/agenttrust.sqlite3 automatically.
# DATABASE_URL=postgresql://user:password@host:5432/agentlayer
SECRET_KEY=replace-me
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1:5000/api/v1/oauth/github/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:5000/api/v1/oauth/x/callback
MOLTBOOK_APP_KEY=
MOLTBOOK_VERIFY_URL=https://moltbook.com/api/v1/agents/verify-identity
